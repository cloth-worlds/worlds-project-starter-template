# API Authentication
API_BEARER_TOKEN=your-api-bearer-token

# App GraphQL Configuration (TODO: replace MY_APP_ with your prefix)
MY_APP_HTTP_ENDPOINT=https://your-graphql-endpoint/graphql
MY_APP_WS_ENDPOINT=wss://your-graphql-endpoint/graphql
MY_APP_TOKEN_ID=your-token-id
MY_APP_TOKEN_VALUE=your-token-value
MY_APP_ENV=development

# Uvicorn
HOT_RELOAD=false

# Logging
APP_LOG_LEVEL=INFO
